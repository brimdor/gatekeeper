# Gatekeeper - Policy Gateway for Google Workspace APIs
# Copy this file to .env and fill in your values.

# Server
GATEKEEPER_HOST=127.0.0.1
GATEKEEPER_PORT=8080
GATEKEEPER_DEBUG=false

# Database
GATEKEEPER_DATABASE_URL=sqlite+aiosqlite:///./gatekeeper.db

# Google OAuth (required for Gmail, Drive, Calendar)
# Get these from: https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Desktop app type)
GATEKEEPER_GOOGLE_CLIENT_ID=
GATEKEEPER_GOOGLE_CLIENT_SECRET=
GATEKEEPER_GOOGLE_TOKEN_FILE=./google_token.json

# Admin credentials (auto-generated on first run if left empty)
# Check gatekeeper_secrets.json after first init for the generated password
GATEKEEPER_ADMIN_USERNAME=admin
GATEKEEPER_ADMIN_PASSWORD=

# Security (auto-generated on first run if left empty)
GATEKEEPER_SECRET_KEY=
GATEKEEPER_ENCRYPTION_KEY=
GATEKEEPER_API_KEY_PREFIX=gkp_

# CORS origins (JSON array format)
GATEKEEPER_CORS_ORIGINS=["http://localhost:8080"]

# Rate limiting
GATEKEEPER_RATE_LIMIT_PER_MINUTE=120

# Modules (enable/disable which Google APIs are proxied)
GATEKEEPER_DRIVE_ENABLED=false
GATEKEEPER_GMAIL_ENABLED=false
GATEKEEPER_CALENDAR_ENABLED=false

# Display timezone for timestamps (IANA timezone name, default: America/Chicago)
# Stored datetimes are always UTC; this only affects display formatting.
# Examples: America/New_York, Europe/London, US/Pacific, Asia/Tokyo
GATEKEEPER_DISPLAY_TIMEZONE=America/Chicago

# MCP Server
GATEKEEPER_MCP_ENABLED=true
GATEKEEPER_MCP_ALLOWED_HOSTS=[]