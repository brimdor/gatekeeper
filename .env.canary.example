# Gatekeeper Canary — .env template
# Copy this to .env.canary and fill in your values.

# Server (inside the container)
GATEKEEPER_HOST=0.0.0.0
GATEKEEPER_PORT=8080
GATEKEEPER_DEBUG=true

# Database (inside the /data volume — isolated from production)
GATEKEEPER_DATABASE_URL=sqlite+aiosqlite:////data/gatekeeper.db
GATEKEEPER_GOOGLE_TOKEN_FILE=/data/google_token.json

# Google OAuth (same credentials as production for functionality testing)
GATEKEEPER_GOOGLE_CLIENT_ID=
GATEKEEPER_GOOGLE_CLIENT_SECRET=

# Admin credentials (auto-generated on first init)
GATEKEEPER_ADMIN_USERNAME=admin
GATEKEEPER_ADMIN_PASSWORD=

# Security (auto-generated on first init)
GATEKEEPER_SECRET_KEY=
GATEKEEPER_ENCRYPTION_KEY=
GATEKEEPER_API_KEY_PREFIX=gkp_

# CORS origins
GATEKEEPER_CORS_ORIGINS=["http://localhost:8082", "http://127.0.0.1:8082"]

# Rate limiting (relaxed for testing)
GATEKEEPER_RATE_LIMIT_PER_MINUTE=300

# Modules — enable all for testing
GATEKEEPER_DRIVE_ENABLED=true
GATEKEEPER_GMAIL_ENABLED=true
GATEKEEPER_CALENDAR_ENABLED=true

# MCP — more permissive for canary testing
GATEKEEPER_MCP_ENABLED=true
GATEKEEPER_MCP_ALLOWED_HOSTS=["*"]

# Display timezone
GATEKEEPER_DISPLAY_TIMEZONE=America/Chicago
